              "name": "groq-api-key",
              "value": "[parameters('groqApiKey')]"
            },
            {
              "name": "appinsights-connection-string",
              "value": "[parameters('appInsightsConnectionString')]"
            }
          ]
        },
        "template": {
          "containers": [
            {
              "name": "gateway",
              "image": "[parameters('initialImage')]",
              "resources": {
                "cpu": "[json('0.5')]",
                "memory": "1Gi"
              },
              "env": [
                {
                  "name": "ENVIRONMENT",
                  "value": "[parameters('environment')]"
                },
                {
                  "name": "PORT",
                  "value": "8000"
                },
                {
                  "name": "LOG_FORMAT",
                  "value": "json"
                },
                {
                  "name": "LLM_PROVIDER",
                  "value": "groq"
                },
                {
                  "name": "GROQ_MODEL",
                  "value": "[parameters('groqModel')]"
                },
                {
                  "name": "GROQ_API_KEY",
                  "secretRef": "groq-api-key"
                },
                {
                  "name": "LANGFUSE_ENABLED",
                  "value": "[string(parameters('langfuseEnabled'))]"
                },
                {
                  "name": "LANGFUSE_PUBLIC_KEY",
                  "value": "[parameters('langfusePublicKey')]"
                },
                {
                  "name": "LANGFUSE_SECRET_KEY",
                  "secretRef": "langfuse-secret-key"
                },
                {
                  "name": "LANGFUSE_HOST",
                  "value": "[parameters('langfuseHost')]"
                },
                {
                  "name": "APPLICATIONINSIGHTS_CONNECTION_STRING",
                  "secretRef": "appinsights-connection-string"
                }
              ]
            }
          ],
          "scale": {
            "minReplicas": "[parameters('minReplicas')]",
            "maxReplicas": "[parameters('maxReplicas')]",
            "rules": [
              {
                "name": "http-scale",
                "http": {
                  "metadata": {
                    "concurrentRequests": "20"
                  }
                }
              }
            ]
          }
        }
      }
    },
    {
      "type": "Microsoft.Authorization/roleAssignments",
      "apiVersion": "2022-04-01",
      "name": "[guid(resourceId('Microsoft.App/containerApps', parameters('appName')), variables('acrPullRoleDefinitionId'), resourceGroup().id)]",
      "properties": {
        "roleDefinitionId": "[subscriptionResourceId('Microsoft.Authorization/roleDefinitions', variables('acrPullRoleDefinitionId'))]",
        "principalId": "[reference(resourceId('Microsoft.App/containerApps', parameters('appName')), '2023-11-02-preview', 'full').identity.principalId]",
        "principalType": "ServicePrincipal"
      },
      "dependsOn": [
        "[resourceId('Microsoft.App/containerApps', parameters('appName'))]"
      ]
    }
  ],
  "outputs": {
