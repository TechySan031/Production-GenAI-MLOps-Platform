# =============================================================================
# GenAI MLOps Platform
# =============================================================================

# --- Application ---
APP_NAME="GenAI MLOps Platform"
APP_VERSION="0.1.0"
ENVIRONMENT="development"
DEBUG=true

# --- Server ---
HOST="0.0.0.0"
PORT=8000

# --- LLM Provider ---
LLM_PROVIDER="openai"

# =============================================================================
# OpenAI
# =============================================================================

OPENAI_API_KEY="sk-your-key-here"
OPENAI_MODEL="gpt-4o-mini"
OPENAI_TIMEOUT=30
OPENAI_MAX_RETRIES=3

# =============================================================================
# Azure OpenAI
# =============================================================================

AZURE_OPENAI_API_KEY=""
AZURE_OPENAI_ENDPOINT=""
AZURE_OPENAI_API_VERSION="2024-10-21"
AZURE_OPENAI_DEPLOYMENT=""

# =============================================================================
# Langfuse
# =============================================================================

LANGFUSE_ENABLED=false
LANGFUSE_PUBLIC_KEY=""
LANGFUSE_SECRET_KEY=""
LANGFUSE_HOST="https://cloud.langfuse.com"

# =============================================================================
# Logging
# =============================================================================

LOG_LEVEL="INFO"
LOG_FORMAT="text"

# =============================================================================
# CORS
# =============================================================================

ALLOWED_ORIGINS='["http://localhost:3000","http://localhost:8000"]'

# ── Azure infrastructure (Phase 4) ───────────────────────────────────────────
# Set these after running 'make infra-staging'. Values come from deployment outputs.

RESOURCE_GROUP=genai-gateway-rg
STAGING_APP_NAME=genai-gateway-staging
PROD_APP_NAME=genai-gateway-production
KEY_VAULT_NAME=genai-gateway-kv-stag-xxxx   # suffix is from uniqueString()

# ACR — set after 'make infra-outputs'
ACR_NAME=genaigatewaycrstagi123456            # alphanumeric, from Bicep output
ACR_LOGIN_SERVER=genaigatewaycrstagi123456.azurecr.io

# Azure OIDC (these go in GitHub Secrets, never .env)
# AZURE_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# AZURE_TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# AZURE_SUBSCRIPTION_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx