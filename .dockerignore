# ─────────────────────────────────────────────────────────────────────────────
# Docker build context exclusions
#
# Reduces build context size and prevents sensitive files from being
# copied into the Docker image.
# ─────────────────────────────────────────────────────────────────────────────

# Version control
.git
.github
.gitignore

# Python
__pycache__
*.py[cod]
*$py.class
*.egg-info
dist
build
.venv
venv
env

# Testing & Quality
.pytest_cache
.mypy_cache
.ruff_cache
htmlcov
.coverage
coverage.xml

# Environment & Secrets
.env
.env.*
!.env.example

# Infrastructure
infra/
*.tfstate
*.tfvars

# Documentation
*.md
LICENSE
docs/

# IDE
.vscode
.idea

# Frontend (not needed in backend container)
frontend/
node_modules/

# Docker
docker-compose.yml
Dockerfile

# Misc
*.log
eval_results.json
review_bundle.txt
structure.txt
Makefile
